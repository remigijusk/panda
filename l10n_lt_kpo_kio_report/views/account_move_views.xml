<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_move_form_inherit_lt_kpo" model="ir.ui.view">
        <field name="name">account.move.form.inherit.lt.kpo</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <!-- Pridedame spausdinimo mygtuką į Header -->
            <xpath expr="//header" position="inside">
                <button name="action_print_kpo_kio" string="Spausdinti KPO/KIO" type="object" 
                        class="btn-primary" invisible="state != 'posted' or journal_id.type != 'cash'"/>
            </xpath>
            
            <!-- Pridedame laukus į formą po "Journal" (Žurnalas) lauko -->
            <xpath expr="//field[@name='journal_id']" position="after">
                <field name="x_pagrindas" placeholder="Surenkama iš etiketės..."/>
                <field name="x_suma_zodziais" placeholder="Generuojama lietuviškai..."/>
            </xpath>
        </field>
    </record>
</odoo>
