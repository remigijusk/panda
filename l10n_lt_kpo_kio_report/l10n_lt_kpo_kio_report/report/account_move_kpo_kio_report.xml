<?xml version="1.0" encoding="utf-8"?>
<odoo>
    
    <record id="action_report_lt_kpo_kio" model="ir.actions.report">
        <field name="name">Kasos orderis (KPO/KIO)</field>
        <field name="model">account.move</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">l10n_lt_kpo_kio_report.report_kpo_kio_template</field>
        <field name="report_file">l10n_lt_kpo_kio_report.report_kpo_kio_template</field>
        <field name="print_report_name">'Kasos_Orderis_%s' % (object.name or 'Naujas')</field>
        <field name="binding_model_id" ref="account.model_account_move"/>
        <field name="binding_type">report</field>
    </record>

    <template id="report_kpo_kio_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.external_layout">
                    <div class="page" style="font-size: 14px;">
                        
                        <t t-set="is_kpo" t-value="False"/>
                        <t t-set="total_amount" t-value="0.0"/>
                        <t t-set="partner_name" t-value="o.partner_id.name or 'Nenurodyta'"/>
                        
                        <t t-foreach="o.line_ids" t-as="line">
                            <t t-if="line.account_id.account_type == 'asset_cash'">
                                <t t-if="line.debit > 0">
                                    <t t-set="is_kpo" t-value="True"/>
                                    <t t-set="total_amount" t-value="line.debit"/>
                                </t>
                                <t t-if="line.credit > 0">
                                    <t t-set="is_kpo" t-value="False"/>
                                    <t t-set="total_amount" t-value="line.credit"/>
                                </t>
                            </t>
                        </t>

                        <div class="row mt32 mb32 border-bottom pb-3">
                            <div class="col-6">
                                <strong><span t-field="o.company_id.name"/></strong><br/>
                                Įmonės kodas: <span t-field="o.company_id.company_registry"/><br/>
                                PVM mokėtojo kodas: <span t-field="o.company_id.vat"/><br/>
                                Adresas: <span t-field="o.company_id.street"/>, <span t-field="o.company_id.city"/>
                            </div>
                            <div class="col-6 text-right">
                                <h3 class="mb-1">
                                    <t t-if="is_kpo">KASOS PAJAMŲ ORDERIS</t>
                                    <t t-else="">KASOS IŠLAIDŲ ORDERIS</t>
                                </h3>
                                <strong>Numeris:</strong> <span t-field="o.name"/><br/>
                                <strong>Data:</strong> <span t-field="o.date"/><br/>
                            </div>
                        </div>

                        <div class="row mb-4">
                            <div class="col-12">
                                <p class="mb-1">
                                    <t t-if="is_kpo"><strong>Gauta iš: </strong></t>
                                    <t t-else=""><strong>Sumokėta (išduota) kam: </strong></t>
                                    <span t-esc="partner_name"/>
                                </p>
                                <p class="mb-1">
                                    <strong>Pagrindas: </strong> 
                                    <t t-if="o.x_pagrindas">
                                        <span t-field="o.x_pagrindas"/>
                                    </t>
                                    <t t-else="">
                                        <span t-field="o.ref"/>
                                    </t>
                                </p>
                            </div>
                        </div>

                        <table class="table table-bordered table-sm mb-4">
                            <thead class="thead-light">
                                <tr>
                                    <th>Koresponduojanti sąskaita</th>
                                    <th>Paskirtis (Etiketė)</th>
                                    <th class="text-right">Suma</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="o.line_ids" t-as="line">
                                    <t t-if="line.account_id.account_type != 'asset_cash'">
                                        <tr>
                                            <td>
                                                <span t-field="line.account_id.code"/> - <span t-field="line.account_id.name"/>
                                            </td>
                                            <td>
                                                <span t-field="line.name"/>
                                            </td>
                                            <td class="text-right">
                                                <t t-if="is_kpo">
                                                    <span t-esc="line.credit" t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
                                                </t>
                                                <t t-else="">
                                                    <span t-esc="line.debit" t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
                                                </t>
                                            </td>
                                        </tr>
                                    </t>
                                </t>
                            </tbody>
                        </table>

                        <div class="row mb-5">
                            <div class="col-12">
                                <strong>Bendra suma: </strong> 
                                <span t-esc="total_amount" t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
                                <br/><br/>
                                <strong>Suma žodžiais: </strong> 
                                <t t-if="o.x_suma_zodziais">
                                    <span t-field="o.x_suma_zodziais"/>
                                </t>
                                <t t-else="">
                                    ...................................................................................................................................................
                                </t>
                            </div>
                        </div>

                        <div class="row mt-5 pt-5">
                            <div class="col-4 text-center">
                                _______________________<br/>
                                (Vadovo parašas)
                            </div>
                            <div class="col-4 text-center">
                                _______________________<br/>
                                (Vyr. buhalterio parašas)
                            </div>
                            <div class="col-4 text-center">
                                _______________________<br/>
                                <t t-if="is_kpo">(Kasininko parašas)</t>
                                <t t-else="">(Gavusiojo asmens parašas)</t>
                            </div>
                        </div>

                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>