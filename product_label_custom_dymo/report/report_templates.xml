<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <template id="report_product_label_custom_dymo">
        <t t-call="web.basic_layout">
            <t t-foreach="docs" t-as="o">
                <t t-set="barcode" t-value="o.barcode or ''"/>
                <div class="page" style="margin: 0; padding: 0;">
                    <div style="width: 45.5mm; height: 7.5mm; padding: 0; margin: 0;">
                        <div style="width: 100%; height: 5.5mm; padding: 0; margin: 0;">
                            <div style="height: 1mm;"></div>
                            <img t-att-src="'/report/barcode/Code128/%s?width=400&amp;height=25&amp;humanreadable=0' % barcode"
                                 style="width: 45.5mm; height: 4mm; object-fit: contain; display: block; margin-left: -6mm;"/>
                        </div>
                        <div style="font-size: 5pt; text-align: left; margin-left: 2mm; margin-top: -1mm;">
                            <span t-esc="barcode"/>
                        </div>

                        <div style="font-size: 10pt; font-weight: bold; text-align: left; margin-left: 2mm; margin-top: 0mm;
                            white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
                            <span t-esc="o.display_name"/>
                        </div>


                        <div style="text-align: left; margin-top: -2mm; margin-left: 2mm;">
                            <span style="font-size: 28pt; font-weight: 900;">
                                <t t-esc="o.final_price_with_tax"/>
                            </span>
                            <span style="font-size: 12pt; font-weight: bold;">
                                <t t-esc="o.final_currency_symbol"/>/<t t-esc="o.final_base_unit_name"/>
                            </span>
                        </div>
                        <div style="font-size: 8pt; text-align: left; margin-left: 2mm; margin-top: 0mm; font-weight: bold;">
                            Country of origin: <t t-esc="o.final_country_name"/>
                        </div>
                    </div>
                </div>
            </t>
        </t>
    </template>

    <record id="report_product_label_custom_dymo_action" model="ir.actions.report">
        <field name="name">Product Label Custom Dymo</field>
        <field name="model">product.product</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">product_label_custom_dymo.report_product_label_custom_dymo</field>
        <field name="report_file">product_label_custom_dymo.report_product_label_custom_dymo</field>
        <field name="paperformat_id" ref="product_label_custom_dymo.paperformat_custom_dymo"/>
        <field name="print_report_name">'Custom Label - %s' % object.name</field>
        <field name="binding_model_id" ref="product.model_product_product"/>
        <field name="binding_type">report</field>
    </record>

</odoo>
