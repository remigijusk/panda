<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="paperformat_kpo_kio" model="report.paperformat">
        <field name="name">KPO/KIO Final (A4)</field>
        <field name="default" eval="True"/>
        <field name="format">A4</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">10</field>
        <field name="margin_bottom">10</field>
        <field name="margin_left">10</field>
        <field name="margin_right">10</field>
        <field name="header_line" eval="False"/>
        <field name="header_spacing">0</field>
        <field name="dpi">90</field>
    </record>

    <record id="action_report_kpo_pos" model="ir.actions.report">
        <field name="name">KPO (A4) POS</field>
        <field name="model">pos.order</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">l10n_lt_kpo_kio.report_kpo_pos_template</field>
        <field name="report_file">l10n_lt_kpo_kio.report_kpo_pos_template</field>
        <field name="print_report_name">'KPO_' + object.pos_reference</field>
        <field name="binding_model_id" ref="point_of_sale.model_pos_order"/>
        <field name="binding_type">report</field>
        <field name="paperformat_id" ref="paperformat_kpo_kio"/>
    </record>

    <record id="action_report_kpo_kio_account" model="ir.actions.report">
        <field name="name">Spausdinti KPO / KIO (A4)</field>
        <field name="model">account.bank.statement.line</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">l10n_lt_kpo_kio.report_kpo_kio_account_template</field>
        <field name="report_file">l10n_lt_kpo_kio.report_kpo_kio_account_template</field>
        <field name="print_report_name">(object.amount &gt; 0 and 'KPO_' or 'KIO_') + str(object.move_id.name).replace('/', '_')</field>
        <field name="binding_model_id" ref="account.model_account_bank_statement_line"/>
        <field name="binding_type">report</field>
        <field name="paperformat_id" ref="paperformat_kpo_kio"/>
    </record>

    <template id="report_kpo_pos_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.basic_layout">
                    <div class="page" style="font-family: Arial, sans-serif; font-size: 15px; color: black; padding: 10px;">
                        <div style="min-height: 48%;">
                            <div style="text-align: center; margin-bottom: 20px;">
                                <strong style="font-size: 15px;" t-field="o.company_id.name"/>
                                <t t-if="o.company_id.company_registry"><br/>Įmonės kodas: <strong t-field="o.company_id.company_registry"/></t>
                                <t t-if="o.company_id.vat">, PVM kodas: <strong t-field="o.company_id.vat"/></t>
                                <br/><span style="border-top: 1px solid black; padding-top: 2px; font-size: 11px;">(ūkio subjekto pavadinimas, kodas, PVM)</span>
                                <h2 style="margin-top: 15px; font-weight: bold; font-size: 20px;">KASOS PAJAMŲ ORDERIS</h2>
                                <div style="font-size: 18px;">Serija, Nr. <strong style="border: 2px solid black; padding: 3px 15px;"><t t-esc="o.pos_reference"/></strong></div>
                                <div style="margin-top: 10px;">Data: <strong t-field="o.date_order" t-options='{"widget": "date"}'/></div>
                            </div>
                            <table style="width: 100%; border-collapse: collapse; text-align: center; border: 2px solid black; margin-bottom: 20px; font-size: 14px;">
                                <tr style="background-color: #f2f2f2;">
                                    <th style="border: 1px solid black; padding: 7px; width: 25%;">Korespondentinė sąskaita</th>
                                    <th style="border: 1px solid black; padding: 7px; width: 25%;">Analitinės apskaitos šifras</th>
                                    <th style="border: 1px solid black; padding: 7px; width: 25%;">Suma (Eur)</th>
                                    <th style="border: 1px solid black; padding: 7px; width: 25%;">Suma (ct)</th>
                                </tr>
                                <tr>
                                    <td style="border: 1px solid black; padding: 12px; font-size: 16px;"><span t-field="o.kpo_journal_account"/></td>
                                    <td style="border: 1px solid black; padding: 12px;"></td>
                                    <td style="border: 1px solid black; padding: 12px; font-weight: bold; font-size: 16px;"><span t-field="o.lt_amount_eur"/></td>
                                    <td style="border: 1px solid black; padding: 12px; font-weight: bold; font-size: 16px;"><span t-esc="'{:02d}'.format(o.lt_amount_ct)"/></td>
                                </tr>
                            </table>
                            <div style="line-height: 2.2; font-size: 15px;">
                                <div><strong style="width: 120px; display: inline-block;">Priimta iš: </strong>
                                    <span style="border-bottom: 1px solid black; padding: 0 10px; min-width: 80%; display: inline-block;">
                                        <t t-if="o.partner_id"><strong t-field="o.partner_id.name"/></t><t t-else="">_____________________________________</t>
                                    </span>
                                </div>
                                <div style="margin-top: 10px;"><strong style="width: 120px; display: inline-block;">Pagrindas: </strong>
                                    <strong style="border-bottom: 1px solid black; padding: 0 10px; min-width: 80%; display: inline-block; font-size: 14px;"><span t-field="o.kpo_base_text"/></strong>
                                </div>
                                <div style="margin-top: 10px;"><strong>Suma žodžiais: </strong>
                                    <strong style="border-bottom: 1px solid black; padding: 0 10px; text-transform: capitalize; font-size: 14px;"><span t-field="o.lt_amount_words"/></strong>
                                    <span> Eur, </span><strong style="border-bottom: 1px solid black; padding: 0 5px; font-size: 14px;"><span t-esc="'{:02d}'.format(o.lt_amount_ct)"/></strong><span> ct.</span>
                                </div>
                            </div>
                            <div style="margin-top: 30px; border-top: 1px solid black; padding-top: 15px;">
                                <div style="float: left; width: 45%; font-size: 14px;"><strong>Vyr. buhalteris: </strong> <span style="display: inline-block; width: 140px; border-bottom: 1px solid black;">&#160;</span><br/><span style="font-size: 11px; margin-left: 140px; color: #555;">(parašas)</span></div>
                                <div style="float: right; width: 48%; font-size: 14px; text-align: right;"><strong>Kasininkas: </strong> <span style="display: inline-block; border-bottom: 1px solid black; min-width: 100px; text-align: left;"><t t-esc="o.cashier_name"/><t t-if="o.cashier_signature"><img t-att-src="image_data_uri(o.cashier_signature)" style="max-height: 40px; vertical-align: bottom; margin-left: 10px; margin-bottom: -10px;"/></t></span><br/><span style="font-size: 11px; margin-right: 50px; color: #555;">(parašas)</span></div>
                                <div style="clear: both;"></div>
                            </div>
                        </div>

                        <div style="border-top: 1px dashed black; padding-top: 15px; margin-top: 25px; margin-bottom: 25px;">
                            <div style="text-align: center; position: relative; top: -25px;"><span style="background: white; padding: 0 15px; font-style: italic; font-size: 12px; color: #555;">kirpimo linija</span></div>
                        </div>

                        <div style="min-height: 45%;">
                            <div style="text-align: center; margin-bottom: 15px;">
                                <strong style="font-size: 14px;" t-field="o.company_id.name"/>
                                <t t-if="o.company_id.company_registry"><br/>Įmonės kodas: <strong t-field="o.company_id.company_registry"/></t>
                                <t t-if="o.company_id.vat">, PVM kodas: <strong t-field="o.company_id.vat"/></t>
                            </div>
                            <div style="text-align: center;">
                                <h3 style="margin:0; font-weight: bold; font-size: 18px;">Kasos pajamų orderio KVITAS</h3>
                                <div style="margin-top: 5px; font-size: 16px;">Serija, Nr. <strong style="border: 2px solid black; padding: 2px 10px;"><t t-esc="o.pos_reference"/></strong></div>
                            </div>
                            <div style="margin-top: 20px; line-height: 2; font-size: 15px;">
                                <div><strong style="width: 100px; display: inline-block;">Priimta iš: </strong>
                                    <strong style="border-bottom: 1px solid black; padding: 0 10px; min-width: 80%; display: inline-block; font-size: 14px;"><t t-if="o.partner_id"><span t-field="o.partner_id.name"/></t><t t-else="">_______________________________</t></strong>
                                </div>
                                <div style="margin-top: 5px;"><strong style="width: 100px; display: inline-block;">Pagrindas: </strong>
                                    <strong style="border-bottom: 1px solid black; padding: 0 10px; min-width: 80%; display: inline-block; font-size: 14px;"><span t-field="o.kpo_base_text"/></strong>
                                </div>
                                <div style="margin-top: 10px;"><strong>Suma: </strong>
                                    <strong style="border-bottom: 2px solid black; padding: 0 10px; font-size: 16px;"><span t-field="o.lt_amount_eur"/> Eur, <span t-esc="'{:02d}'.format(o.lt_amount_ct)"/> ct. (<span t-field="o.lt_amount_words"/>)</strong>
                                </div>
                                <div style="margin-top: 10px;"><strong>Data: </strong> <strong t-field="o.date_order" t-options='{"widget": "date"}'/></div>
                            </div>
                            <div style="margin-top: 30px; border-top: 1px solid black; padding-top: 15px;">
                                <div style="float: right; width: 48%; font-size: 14px; text-align: right;"><strong>Kasininkas: </strong> <span style="display: inline-block; border-bottom: 1px solid black; min-width: 100px; text-align: left;"><t t-esc="o.cashier_name"/><t t-if="o.cashier_signature"><img t-att-src="image_data_uri(o.cashier_signature)" style="max-height: 40px; vertical-align: bottom; margin-left: 10px; margin-bottom: -10px;"/></t></span><br/><span style="font-size: 11px; margin-right: 50px; color: #555;">(parašas)</span></div>
                                <div style="clear: both;"></div>
                            </div>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>

