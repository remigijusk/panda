<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_report_kpo_kio" model="ir.actions.report">
        <field name="name">KPO / KIO Orderis</field>
        <field name="model">account.payment</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">l10n_lt_kpo_kio.report_kpo_kio_document</field>
        <field name="report_file">l10n_lt_kpo_kio.report_kpo_kio_document</field>
        <field name="print_report_name">(object.payment_type == 'inbound' and 'KPO_' or 'KIO_') + object.name</field>
        <field name="binding_model_id" ref="account.model_account_payment"/>
        <field name="binding_type">report</field>
    </record>
</odoo>
