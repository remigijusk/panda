<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="l10n_lt_kpo_kio.ReceiptScreen" t-inherit="point_of_sale.ReceiptScreen" t-inherit-mode="extension" owl="1">
        <xpath expr="//div[hasclass('buttons')]" position="inside">
            <t t-if="this.getKpoEnabled and this.getKpoEnabled()">
                <div class="button print-kpo" t-on-click="downloadKPO" style="margin-top: 10px; background-color: #00A09D; color: white; border-radius: 3px; font-weight: bold; cursor: pointer;">
                    <i class="fa fa-print"></i> Spausdinti KPO (A4)
                </div>
            </t>
        </xpath>
    </t>
</templates>
