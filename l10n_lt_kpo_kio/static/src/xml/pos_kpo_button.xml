<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="l10n_lt_kpo_kio.ReceiptScreen" t-inherit="point_of_sale.ReceiptScreen" t-inherit-mode="extension">
        <xpath expr="//div[hasclass('buttons')] | //div[hasclass('actions')]" position="inside">
            <button t-att-style="this.getKpoBtnStyle()" class="button highlight" t-on-click="clickKpoBtn">
                <i class="fa fa-print"></i> Spausdinti KPO (A4)
            </button>
        </xpath>
    </t>
</templates>
