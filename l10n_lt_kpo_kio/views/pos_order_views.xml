<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_pos_pos_form_inherit_kpo_final" model="ir.ui.view">
        <field name="name">pos.order.form.inherit.kpo.final</field>
        <field name="model">pos.order</field>
        <field name="inherit_id" ref="point_of_sale.view_pos_pos_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <field name="has_kpo_payment" invisible="1"/>
                <button name="%(l10n_lt_kpo_kio.action_report_kpo_pos_final)d"
                        type="action"
                        string="Spausdinti KPO (A4)"
                        class="oe_highlight"
                        invisible="not has_kpo_payment"/>
            </xpath>
        </field>
    </record>
</odoo>
