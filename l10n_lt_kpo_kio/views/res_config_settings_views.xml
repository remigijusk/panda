        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="point_of_sale.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//*[@id='pos_accounting_section']" position="inside">
                <setting id="kpo_print_setting" help="Leidžia atspausdinti A4 formato KPO orderį tiesiai iš kasos kvito ekrano.">
                    <field name="pos_iface_print_kpo"/>
                </setting>
            </xpath>
        </field>
    </record>
</odoo>
