<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="res_config_settings_view_form_kpo_final" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.point_of_sale.final</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="point_of_sale.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//app[@name='point_of_sale']" position="inside">
                <block title="Lietuvos KPO Nustatymai" id="lt_kpo_settings_block">
                    <setting id="print_kpo_final" help="Leidžia atspausdinti A4 formato Kasos Pajamų Orderį iš Pardavimo taško.">
                        <field name="pos_iface_print_kpo"/>
                    </setting>
                </block>
            </xpath>
        </field>
    </record>
</odoo>
