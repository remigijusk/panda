<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_move_form_inherit_gemini" model="ir.ui.view">
        <field name="name">account_move.form.inherit.gemini</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <!-- Mygtukas matomas tik juodraščiuose ir tik kvitų žurnale/tipe -->
                <button name="action_scan_receipt_ai" 
                        string="GEMINI SKENUOTI" 
                        type="object" 
                        class="oe_highlight"
                        invisible="state != 'draft' or (move_type != 'in_receipt' and journal_id.code != 'KVIT')"/>
            </xpath>
        </field>
    </record>
</odoo>
