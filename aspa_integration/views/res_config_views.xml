<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.aspa</field>
        <field name="model">res.config.settings</field>
        <field name="priority" eval="45"/>
        <field name="inherit_id" ref="point_of_sale.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//block[@id='pos_payment_section']" position="after">
                <block title="ASPA Settings" name="aspa_settings">
                    <setting id="aspa_api_url" help="ASPA URL" company_dependent="1">
                        <field name="aspa_api_url" class="d-block" style="width: 100%;"/>
                    </setting>
                </block>
            </xpath>
        </field>
    </record>
</odoo>
