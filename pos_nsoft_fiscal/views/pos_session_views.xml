<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <!-- Add NSoft action buttons to the pos.session form header -->
  <record id="view_pos_session_form_nsoft" model="ir.ui.view">
    <field name="name">pos.session.form.inherit.nsoft</field>
    <field name="model">pos.session</field>
    <field name="inherit_id" ref="point_of_sale.view_pos_session_form"/>
    <field name="arch" type="xml">
      <xpath expr="//sheet" position="before">
        <header position="inside">
          <button name="print_nsoft_x_report" type="object" string="i.EKA: X ataskaita"
                  class="btn-secondary" invisible="not config_id or state != 'opened'"/>
          <button name="print_nsoft_z_report" type="object" string="i.EKA: Z ataskaita"
                  class="btn-secondary" invisible="not config_id or state != 'opened'"
                  confirm="Ar tikrai uždaryti fiskalinę dieną (Z ataskaita)?"/>
          <button name="action_nsoft_min_day" type="object" string="i.EKA: Min. dienos"
                  class="btn-secondary" invisible="state != 'opened'"/>
          <button name="action_nsoft_sync" type="object" string="i.EKA: Sinchr."
                  class="btn-secondary" invisible="state != 'opened'"/>
          <button name="action_nsoft_info" type="object" string="i.EKA: Būklė"
                  class="btn-secondary" invisible="state != 'opened'"/>
        </header>
      </xpath>
    </field>
  </record>

  <!-- Operation wizard -->
  <record id="view_pos_nsoft_op_wizard_form" model="ir.ui.view">
    <field name="name">pos.nsoft.op.wizard.form</field>
    <field name="model">pos.nsoft.op.wizard</field>
    <field name="arch" type="xml">
      <form string="nSoft operacija">
        <group>
          <field name="pos_config_id"/>
          <field name="operation"/>
        </group>
        <group string="Dokumentas" invisible="operation == 'non_fis_doc'">
          <field name="description"/>
          <field name="quantity"/>
          <field name="unit_price"/>
          <field name="line_amount"/>
          <field name="vat_code"/>
          <field name="reference_doc" invisible="operation != 'transfer'"/>
        </group>
        <group string="Laisvo teksto dokumentas" invisible="operation != 'non_fis_doc'">
          <field name="name"/>
          <field name="free_text"/>
        </group>
        <footer>
          <button name="action_run" type="object" string="Vykdyti" class="btn-primary"/>
          <button string="Atšaukti" class="btn-secondary" special="cancel"/>
        </footer>
      </form>
    </field>
  </record>

  <record id="action_pos_nsoft_op_wizard" model="ir.actions.act_window">
    <field name="name">nSoft: operacija</field>
    <field name="res_model">pos.nsoft.op.wizard</field>
    <field name="view_mode">form</field>
    <field name="target">new</field>
  </record>

  <!-- History / report wizard -->
  <record id="view_pos_nsoft_history_wizard_form" model="ir.ui.view">
    <field name="name">pos.nsoft.history.wizard.form</field>
    <field name="model">pos.nsoft.history.wizard</field>
    <field name="arch" type="xml">
      <form string="nSoft istorija / ataskaita">
        <group>
          <field name="pos_config_id"/>
          <field name="report"/>
          <field name="spec"/>
          <field name="value_from"/>
          <field name="value_to"/>
        </group>
        <group>
          <field name="result" widget="text" readonly="1"/>
        </group>
        <footer>
          <button name="action_run" type="object" string="Gauti" class="btn-primary"/>
          <button string="Uždaryti" class="btn-secondary" special="cancel"/>
        </footer>
      </form>
    </field>
  </record>

  <record id="action_pos_nsoft_history_wizard" model="ir.actions.act_window">
    <field name="name">nSoft: istorija / ataskaita</field>
    <field name="res_model">pos.nsoft.history.wizard</field>
    <field name="view_mode">form</field>
    <field name="target">new</field>
  </record>

  <!-- Menus under Point of Sale -->
  <menuitem id="menu_pos_nsoft_root"
            name="nSoft i.EKA"
            parent="point_of_sale.menu_point_root"
            sequence="95"/>
  <menuitem id="menu_pos_nsoft_op"
            name="Operacija (pre-order, advance, transfer...)"
            parent="menu_pos_nsoft_root"
            action="action_pos_nsoft_op_wizard"
            sequence="10"/>
  <menuitem id="menu_pos_nsoft_history"
            name="Istorija / ataskaitos"
            parent="menu_pos_nsoft_root"
            action="action_pos_nsoft_history_wizard"
            sequence="20"/>
</odoo>
