<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <record id="res_config_settings_view_form_nsoft" model="ir.ui.view">
    <field name="name">res.config.settings.view.form.inherit.pos.nsoft</field>
    <field name="model">res.config.settings</field>
    <field name="inherit_id" ref="point_of_sale.res_config_settings_view_form"/>
    <field name="arch" type="xml">
      <xpath expr="//block[@id='pos_interface_section']" position="inside">
        <setting id="nsoft_fiscalization" string="nSoft Virtuali Fiskalizacija" help="Tiesiogine i.EKA integracija per nSoft API">
          <field name="pos_nsoft_enabled"/>
          <div class="content-group" invisible="not pos_nsoft_enabled">

            <div class="row mt16"><span class="col-lg-12 o_form_label"><strong>Rysys</strong></span></div>
            <div class="row mt8">
              <label for="pos_nsoft_api_url" class="col-lg-3 o_light_label" string="API URL"/>
              <field name="pos_nsoft_api_url" placeholder="https://nvf.app3.nsoft.eu:30032"/>
            </div>
            <div class="row mt8">
              <label for="pos_nsoft_pos_id" class="col-lg-3 o_light_label" string="POS ID"/>
              <field name="pos_nsoft_pos_id" placeholder="CR-000019280"/>
            </div>
            <div class="row mt8">
              <label for="pos_nsoft_token" class="col-lg-3 o_light_label" string="Bearer Token"/>
              <field name="pos_nsoft_token" password="True"/>
            </div>
            <div class="row mt8">
              <label for="pos_nsoft_mod" class="col-lg-3 o_light_label" string="Rezimas"/>
              <field name="pos_nsoft_mod"/>
            </div>

            <div class="row mt16"><span class="col-lg-12 o_form_label"><strong>Spausdinimo agentas</strong></span></div>
            <div class="row mt8">
              <label for="pos_nsoft_print_agent_url" class="col-lg-3 o_light_label" string="Agent URL"/>
              <field name="pos_nsoft_print_agent_url" placeholder="https://localhost:8443/print"/>
            </div>
            <div class="row mt8">
              <label for="pos_nsoft_printer_host" class="col-lg-3 o_light_label" string="Spausdintuvo IP"/>
              <field name="pos_nsoft_printer_host" placeholder="192.168.192.168"/>
            </div>
            <div class="row mt8">
              <label for="pos_nsoft_printer_port" class="col-lg-3 o_light_label" string="Spausdintuvo portas"/>
              <field name="pos_nsoft_printer_port" placeholder="9100"/>
            </div>

            <div class="row mt16"><span class="col-lg-12 o_form_label"><strong>Kasos nustatymai</strong></span></div>
            <div class="row mt8">
              <label for="pos_nsoft_cashier" class="col-lg-3 o_light_label" string="Kasininkas"/>
              <field name="pos_nsoft_cashier"/>
            </div>
            <div class="row mt8">
              <label for="pos_nsoft_round_cash" class="col-lg-3 o_light_label" string="Apvalinti 5 ct"/>
              <field name="pos_nsoft_round_cash"/>
            </div>
            <div class="row mt8">
              <label for="pos_nsoft_retain_cash" class="col-lg-3 o_light_label" string="Islaikyti grynuosius po Z"/>
              <field name="pos_nsoft_retain_cash"/>
            </div>
            <div class="row mt8">
              <label for="pos_nsoft_output_format" class="col-lg-3 o_light_label" string="Formatas"/>
              <field name="pos_nsoft_output_format"/>
            </div>
            <div class="row mt8">
              <label for="pos_nsoft_line_width" class="col-lg-3 o_light_label" string="Eilutes plotis"/>
              <field name="pos_nsoft_line_width"/>
            </div>

            <div class="row mt16"><span class="col-lg-12 o_form_label"><strong>Mokejimo metodai (API enum)</strong></span></div>
            <div class="row mt8"><label for="pos_nsoft_payment_cash" class="col-lg-3 o_light_label" string="Grynieji"/><field name="pos_nsoft_payment_cash" placeholder="cash"/></div>
            <div class="row mt8"><label for="pos_nsoft_payment_card" class="col-lg-3 o_light_label" string="Banko kortele"/><field name="pos_nsoft_payment_card" placeholder="paymentCard"/></div>
            <div class="row mt8"><label for="pos_nsoft_payment_other_card" class="col-lg-3 o_light_label" string="Kita kortele"/><field name="pos_nsoft_payment_other_card" placeholder="otherCard"/></div>
            <div class="row mt8"><label for="pos_nsoft_payment_voucher" class="col-lg-3 o_light_label" string="Kuponas"/><field name="pos_nsoft_payment_voucher" placeholder="coupon"/></div>
            <div class="row mt8"><label for="pos_nsoft_payment_transfer" class="col-lg-3 o_light_label" string="Pavedimas"/><field name="pos_nsoft_payment_transfer" placeholder="transfer"/></div>
            <div class="row mt8"><label for="pos_nsoft_payment_other" class="col-lg-3 o_light_label" string="Kita"/><field name="pos_nsoft_payment_other" placeholder="other"/></div>

            <div class="row mt16"><span class="col-lg-12 o_form_label"><strong>PVM grupes</strong></span></div>
            <div class="row mt8"><label for="pos_nsoft_vat_group_21" class="col-lg-3 o_light_label" string="21%"/><field name="pos_nsoft_vat_group_21" placeholder="A"/></div>
            <div class="row mt8"><label for="pos_nsoft_vat_group_9" class="col-lg-3 o_light_label" string="9%"/><field name="pos_nsoft_vat_group_9" placeholder="E"/></div>
            <div class="row mt8"><label for="pos_nsoft_vat_group_5" class="col-lg-3 o_light_label" string="5%"/><field name="pos_nsoft_vat_group_5" placeholder="C"/></div>
            <div class="row mt8"><label for="pos_nsoft_vat_group_0" class="col-lg-3 o_light_label" string="0%"/><field name="pos_nsoft_vat_group_0" placeholder="F"/></div>
            <div class="row mt8"><label for="pos_nsoft_vat_group_alcohol" class="col-lg-3 o_light_label" string="Alkoholis"/><field name="pos_nsoft_vat_group_alcohol" placeholder="B"/></div>
            <div class="row mt8"><label for="pos_nsoft_vat_group_deposit" class="col-lg-3 o_light_label" string="Tara / depozitas"/><field name="pos_nsoft_vat_group_deposit" placeholder="T"/></div>
            <div class="row mt8"><label for="pos_nsoft_vat_group_other" class="col-lg-3 o_light_label" string="Ne-PVM"/><field name="pos_nsoft_vat_group_other" placeholder="N"/></div>

            <div class="row mt16">
              <button name="action_test_nsoft_connection" type="object" string="Testuoti rysi" class="btn btn-primary" icon="fa-wifi"/>
              <button name="action_nsoft_get_info" type="object" string="Kasos bukle" class="btn btn-secondary" icon="fa-info-circle"/>
              <button name="action_nsoft_list_registers" type="object" string="Aktyvios kasos" class="btn btn-secondary" icon="fa-list"/>
              <button name="action_nsoft_push_vat" type="object" string="Siusti PVM lentele" class="btn btn-secondary" icon="fa-upload"/>
              <button name="action_nsoft_patch_settings" type="object" string="Atnaujinti kasos nust." class="btn btn-secondary" icon="fa-cog"/>
              <button name="action_nsoft_force_sync" type="object" string="Priverstine sinchr." class="btn btn-secondary" icon="fa-refresh"/>
            </div>

          </div>
        </setting>
      </xpath>
    </field>
  </record>
</odoo>
