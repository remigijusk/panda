<?xml version="1.0" encoding="UTF-8"?>
<!--
  VMI / UAB nSoft reikalavimas:
  Spausdinamas kvitas privalo buti TIK tas, kuri grazino nVirtualFiscal API.
  Odoo standartinis kvito sablonas yra pilnai pakeiciamas - viskas, kas eina i
  spausdintuva, pirma turi praeiti per nVF, nVF perduoda VMI. Jokio papildomo
  spausdinimo nevykdoma.
-->
<templates id="template" xml:space="preserve">
  <t t-name="pos_nsoft_fiscal.OrderReceipt"
     t-inherit="point_of_sale.OrderReceipt"
     t-inherit-mode="extension">

    <xpath expr="//div[hasclass('pos-receipt')]" position="replace">
      <t t-set="nsoft_text" t-value="props.order.nsoft_receipt_text || false"/>
      <t t-set="nsoft_id" t-value="props.order.nsoft_receipt_id || false"/>
      <t t-set="nsoft_err" t-value="props.order.nsoft_error || false"/>

      <div class="pos-receipt">
        <t t-if="nsoft_text">
          <pre style="font-family:'Courier New',monospace;font-size:12px;white-space:pre;margin:0;padding:0;line-height:1.2;"><t t-esc="nsoft_text"/></pre>
          <t t-if="nsoft_id">
            <div class="pos-receipt-center-align" style="margin-top:8px;text-align:center;">
              <img t-att-src="'/report/barcode/QR/' + nsoft_id" style="width:120px;height:120px;margin:0 auto;display:block;"/>
              <div style="font-size:10px;margin-top:4px;">nSoft ID: <t t-esc="nsoft_id"/></div>
            </div>
          </t>
        </t>
        <t t-else="">
          <div style="color:red;text-align:center;padding:20px;border:2px solid red;">
            <strong>FISKALINIS KVITAS NEUZREGISTRUOTAS</strong>
            <div style="font-size:10px;margin-top:8px;">Sis dokumentas neturi fiskalines reiksmes.</div>
            <t t-if="nsoft_err">
              <div style="font-size:10px;margin-top:4px;word-break:break-all;"><t t-esc="nsoft_err"/></div>
            </t>
          </div>
        </t>
      </div>
    </xpath>
  </t>
</templates>
