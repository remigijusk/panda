<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="hr_employee_personal_info_npd" inherit_id="hr.hr_employee_personal_info">
        <xpath expr="//div[hasclass('o_hr_employee_onboarding_form')]" position="inside">
            <div class="mt-4 border-top pt-4">
                <h4>NPD Taikymas</h4>
                <div class="row">
                    <div class="col-md-6">
                        <div class="form-check m-3">
                            <input class="form-check-input" type="checkbox" name="x_is_npd_applied" id="x_is_npd_applied"/>
                            <label class="form-check-label" for="x_is_npd_applied">Taikyti NPD</label>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-check m-3">
                            <input class="form-check-input" type="checkbox" name="x_is_fixed_npd" id="x_is_fixed_npd"/>
                            <label class="form-check-label" for="x_is_fixed_npd">Fiksuotas NPD</label>
                        </div>
                    </div>
                </div>
            </div>
        </xpath>
    </template>
</odoo>
