<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_employee_form_inherit_npd_tutas" model="ir.ui.view">
        <field name="name">hr.employee.form.inherit.npd.tutas</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="NPD (Tutas)" name="npd_tutas_page">
                    <group>
                        <group string="NPD Nustatymai">
                            <field name="x_is_npd_applied"/>
                            <field name="x_is_fixed_npd"/>
                        </group>
                        <group string="Papildoma informacija">
                            <field name="npd_data"/>
                            <field name="npd_suma"/>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
